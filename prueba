  <script>
    const canvas = document.getElementById("graph");
    const ctx = canvas.getContext("2d");

    const kRange = document.getElementById("kRange");
    const aRange = document.getElementById("aRange");
    const kInput = document.getElementById("kInput");
    const aInput = document.getElementById("aInput");
    const applyK = document.getElementById("applyK");
    const applyA = document.getElementById("applyA");
    const kPill = document.getElementById("kPill");
    const aPill = document.getElementById("aPill");
    const formulaText = document.getElementById("formulaText");
    const statusText = document.getElementById("statusText");
    const kError = document.getElementById("kError");
    const aError = document.getElementById("aError");
    const toggleAsymptote = document.getElementById("toggleAsymptote");
    const toggleTrace = document.getElementById("toggleTrace");
    const clearTrace = document.getElementById("clearTrace");
    const reset = document.getElementById("reset");
    const fxRow = document.getElementById("fxRow");

    let state = {
      k: 1,
      a: 2,
      showAsymptote: true,
      traceOn: false,
      traces: []
    };

    const view = {
      xMin: -5,
      xMax: 5,
      yMin: -12,
      yMax: 12,
      pad: 38
    };

    function resizeCanvas(){
      const rect = canvas.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = Math.round(rect.width * dpr);
      canvas.height = Math.round(rect.height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      draw();
    }

    function w(){ return canvas.getBoundingClientRect().width; }
    function h(){ return canvas.getBoundingClientRect().height; }

    function xToPx(x){
      return view.pad + (x - view.xMin) * (w() - 2*view.pad) / (view.xMax - view.xMin);
    }
    function yToPx(y){
      return h() - view.pad - (y - view.yMin) * (h() - 2*view.pad) / (view.yMax - view.yMin);
    }
    function pxToX(px){
      return view.xMin + (px - view.pad) * (view.xMax - view.xMin) / (w() - 2*view.pad);
    }

    function f(x, k=state.k, a=state.a){
      return k * Math.pow(a, x);
    }

    function nice(n){
      if (!Number.isFinite(n)) return "";
      if (Math.abs(n) < 1e-10) return "0";
      if (Math.abs(n) >= 1000) return n.toExponential(2);
      const rounded = Math.round(n * 1000) / 1000;
      return String(rounded).replace(".", ",");
    }

    function fmt(n){
      const rounded = Math.round(n * 1000) / 1000;
      return String(rounded).replace(".", ",");
    }

    function expText(base){
      const rounded = Math.round(base * 1000) / 1000;
      if (Math.abs(rounded - 0.5) < 0.0001) return "(1/2)";
      if (Math.abs(rounded - 1/3) < 0.0008) return "(1/3)";
      return String(rounded).replace(".", ",");
    }

    function updateText(){
      kPill.textContent = fmt(state.k);
      aPill.textContent = fmt(state.a);
      kInput.value = Math.round(state.k * 1000) / 1000;
      aInput.value = Math.round(state.a * 1000) / 1000;
      kRange.value = clamp(state.k, Number(kRange.min), Number(kRange.max));
      aRange.value = clamp(state.a, Number(aRange.min), Number(aRange.max));

      let kPart = "";
      if (state.k === 1) kPart = "";
      else if (state.k === -1) kPart = "-";
      else kPart = fmt(state.k) + "·";

      formulaText.innerHTML = `f(x)=${kPart}${expText(state.a)}<small>x</small>`;

      const position = state.k > 0 ? "por encima del eje x" : state.k < 0 ? "por debajo del eje x" : "sobre el eje x";
      const kEffect = Math.abs(state.k) > 1 ? "estiramiento vertical" : Math.abs(state.k) < 1 && state.k !== 0 ? "compresión vertical" : "curva base";
      const aEffect = state.a > 1 ? "creciente" : state.a > 0 && state.a < 1 ? "decreciente" : "no exponencial usual";
      statusText.innerHTML =
        `<strong>Lectura:</strong> curva ${position}. ` +
        `Efecto de k: <strong>${kEffect}</strong>. ` +
        `Con esta base, la función es <strong>${aEffect}</strong>. ` +
        `Ordenada al origen: <strong>(0, ${fmt(state.k)})</strong>.`;
      updateTable();
    }

    function updateTable(){
      const xs = [-2,-1,0,1,2,3];
      const cells = fxRow.querySelectorAll("td");
      xs.forEach((x, i) => {
        cells[i].textContent = nice(f(x));
      });
    }

    function clamp(v,min,max){
      return Math.min(max, Math.max(min, v));
    }

    function validateA(value){
      if (!Number.isFinite(value)) return "Ingresá un número.";
      if (value <= 0) return "La base debe ser mayor que 0.";
      if (Math.abs(value - 1) < 0.000001) return "a = 1 no se trabaja como función exponencial en esta clase.";
      if (value > 8) return "Para ver mejor el gráfico, usá una base menor o igual a 8.";
      return "";
    }

    function setK(value, addTrace=true){
      if (!Number.isFinite(value)) {
        kError.textContent = "Ingresá un número.";
        return;
      }
      kError.textContent = "";
      if (state.traceOn && addTrace) addCurrentTrace();
      state.k = value;
      updateText();
      draw();
    }

    function setA(value, addTrace=true){
      const err = validateA(value);
      if (err){
        aError.textContent = err;
        return;
      }
      aError.textContent = "";
      if (state.traceOn && addTrace) addCurrentTrace();
      state.a = value;
      updateText();
      draw();
    }

    function addCurrentTrace(){
      if (state.k === 0) return;
      state.traces.push({k: state.k, a: state.a});
      if (state.traces.length > 12) state.traces.shift();
    }

    function drawGrid(){
      ctx.clearRect(0,0,w(),h());

      // background
      ctx.fillStyle = "#fbfdff";
      ctx.fillRect(0,0,w(),h());

      // grid
      ctx.lineWidth = 1;
      ctx.strokeStyle = "#e6edf7";
      ctx.fillStyle = "#6b7788";
      ctx.font = "12px system-ui";

      for (let x = Math.ceil(view.xMin); x <= Math.floor(view.xMax); x++){
        const px = xToPx(x);
        ctx.beginPath();
        ctx.moveTo(px, view.pad);
        ctx.lineTo(px, h()-view.pad);
        ctx.stroke();
      }
      for (let y = Math.ceil(view.yMin); y <= Math.floor(view.yMax); y++){
        const py = yToPx(y);
        ctx.beginPath();
        ctx.moveTo(view.pad, py);
        ctx.lineTo(w()-view.pad, py);
        ctx.stroke();
      }

      // axes
      ctx.strokeStyle = "#1f2d3f";
      ctx.lineWidth = 2;
      if (view.yMin < 0 && view.yMax > 0){
        const y0 = yToPx(0);
        ctx.beginPath();
        ctx.moveTo(view.pad, y0);
        ctx.lineTo(w()-view.pad, y0);
        ctx.stroke();
        ctx.fillText("x", w()-view.pad+8, y0+4);
      }
      if (view.xMin < 0 && view.xMax > 0){
        const x0 = xToPx(0);
        ctx.beginPath();
        ctx.moveTo(x0, view.pad);
        ctx.lineTo(x0, h()-view.pad);
        ctx.stroke();
        ctx.fillText("y", x0+7, view.pad-9);
      }

      // tick labels
      ctx.fillStyle = "#526071";
      ctx.font = "12px system-ui";
      for (let x = Math.ceil(view.xMin); x <= Math.floor(view.xMax); x++){
        if (x === 0) continue;
        ctx.fillText(String(x), xToPx(x)-4, yToPx(0)+17);
      }
      for (let y = Math.ceil(view.yMin); y <= Math.floor(view.yMax); y += 2){
        if (y === 0) continue;
        ctx.fillText(String(y), xToPx(0)+6, yToPx(y)+4);
      }
    }

    function drawAsymptote(){
      if (!state.showAsymptote) return;
      const y0 = yToPx(0);
      ctx.save();
      ctx.strokeStyle = "#ff7b7b";
      ctx.lineWidth = 2;
      ctx.setLineDash([8,7]);
      ctx.beginPath();
      ctx.moveTo(view.pad, y0);
      ctx.lineTo(w()-view.pad, y0);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = "#cc3333";
      ctx.font = "bold 13px system-ui";
      ctx.fillText("Asíntota horizontal: y = 0", view.pad + 10, y0 - 10);
      ctx.restore();
    }

    function drawCurve(k, a, color, alpha=1, lineWidth=3){
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = color;
      ctx.lineWidth = lineWidth;
      ctx.beginPath();
      let started = false;
      const steps = 800;
      for (let i=0; i<=steps; i++){
        const x = view.xMin + (view.xMax-view.xMin) * i/steps;
        const y = k * Math.pow(a, x);
        const px = xToPx(x);
        const py = yToPx(y);
        if (!Number.isFinite(y) || py < -4000 || py > h()+4000){
          started = false;
          continue;
        }
        if (!started){
          ctx.moveTo(px,py);
          started = true;
        } else {
          ctx.lineTo(px,py);
        }
      }
      ctx.stroke();
      ctx.restore();
    }

    function drawPoints(){
      const xs = [-2,-1,0,1,2,3];
      xs.forEach(x => {
        const y = f(x);
        const px = xToPx(x);
        const py = yToPx(y);
        if (py < view.pad - 10 || py > h()-view.pad + 10) return;
        ctx.beginPath();
        ctx.arc(px, py, 4.5, 0, Math.PI*2);
        ctx.fillStyle = "#0a65c7";
        ctx.fill();
        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = 2;
        ctx.stroke();
      });
    }

    function drawTrace(){
      const colors = ["#8ecae6","#219ebc","#ffb703","#fb8500","#90be6d","#bdb2ff","#ffafcc","#a7c957"];
      state.traces.forEach((t, i) => {
        drawCurve(t.k, t.a, colors[i % colors.length], 0.42, 2);
      });
    }

    function drawLabel(){
      const x = 1;
      const y = f(x);
      const px = xToPx(x);
      const py = yToPx(y);
      if (py < view.pad || py > h()-view.pad) return;
      ctx.save();
      ctx.fillStyle = "rgba(10,24,46,.88)";
      ctx.strokeStyle = "rgba(255,255,255,.9)";
      ctx.lineWidth = 1;
      const text = `f(1) = ${nice(y)}`;
      ctx.font = "bold 13px system-ui";
      const tw = ctx.measureText(text).width;
      ctx.beginPath();
      roundRect(ctx, px+10, py-30, tw+18, 25, 10);
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = "#ffffff";
      ctx.fillText(text, px+19, py-13);
      ctx.restore();
    }

    function roundRect(ctx, x, y, width, height, radius) {
      ctx.moveTo(x + radius, y);
      ctx.arcTo(x + width, y, x + width, y + height, radius);
      ctx.arcTo(x + width, y + height, x, y + height, radius);
      ctx.arcTo(x, y + height, x, y, radius);
      ctx.arcTo(x, y, x + width, y, radius);
    }

    function draw(){
      drawGrid();
      drawTrace();
      drawAsymptote();
      drawCurve(state.k, state.a, "#0a65c7", 1, 4);
      drawPoints();
      drawLabel();
    }

    kRange.addEventListener("input", e => setK(Number(e.target.value)));
    aRange.addEventListener("input", e => setA(Number(e.target.value)));
    applyK.addEventListener("click", () => setK(Number(kInput.value)));
    applyA.addEventListener("click", () => setA(Number(aInput.value)));

    kInput.addEventListener("keydown", e => {
      if (e.key === "Enter") setK(Number(kInput.value));
    });
    aInput.addEventListener("keydown", e => {
      if (e.key === "Enter") setA(Number(aInput.value));
    });

    toggleAsymptote.addEventListener("click", () => {
      state.showAsymptote = !state.showAsymptote;
      toggleAsymptote.textContent = state.showAsymptote ? "Asíntota: ON" : "Asíntota: OFF";
      toggleAsymptote.classList.toggle("on", state.showAsymptote);
      toggleAsymptote.classList.toggle("secondary", !state.showAsymptote);
      draw();
    });

    toggleTrace.addEventListener("click", () => {
      state.traceOn = !state.traceOn;
      toggleTrace.textContent = state.traceOn ? "Rastro: ON" : "Rastro: OFF";
      toggleTrace.classList.toggle("on", state.traceOn);
      toggleTrace.classList.toggle("secondary", !state.traceOn);
      if (state.traceOn) addCurrentTrace();
      draw();
    });

    clearTrace.addEventListener("click", () => {
      state.traces = [];
      draw();
    });

    reset.addEventListener("click", () => {
      state.k = 1;
      state.a = 2;
      state.traces = [];
      state.showAsymptote = true;
      state.traceOn = false;
      toggleAsymptote.textContent = "Asíntota: ON";
      toggleAsymptote.classList.add("on");
      toggleAsymptote.classList.remove("secondary");
      toggleTrace.textContent = "Rastro: OFF";
      toggleTrace.classList.remove("on");
      toggleTrace.classList.add("secondary");
      updateText();
      draw();
    });

    document.querySelectorAll("[data-k][data-a]").forEach(btn => {
      btn.addEventListener("click", () => {
        if (state.traceOn) addCurrentTrace();
        state.k = Number(btn.dataset.k);
        state.a = Number(btn.dataset.a);
        updateText();
        draw();
      });
    });

    // small interaction: dragging horizontally over canvas shows local value
    let dragging = false;
    canvas.addEventListener("pointerdown", () => dragging = true);
    canvas.addEventListener("pointerup", () => dragging = false);
    canvas.addEventListener("pointerleave", () => dragging = false);
    canvas.addEventListener("pointermove", e => {
      if (!dragging) return;
      const rect = canvas.getBoundingClientRect();
      const x = pxToX(e.clientX - rect.left);
      const y = f(x);
      draw();
      const px = xToPx(x);
      const py = yToPx(y);
      if (py > view.pad && py < h()-view.pad){
        ctx.save();
        ctx.strokeStyle = "rgba(10,101,199,.35)";
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4,4]);
        ctx.beginPath();
        ctx.moveTo(px, yToPx(0));
        ctx.lineTo(px, py);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.beginPath();
        ctx.arc(px, py, 6, 0, Math.PI*2);
        ctx.fillStyle = "#ffd166";
        ctx.fill();
        ctx.strokeStyle = "#102a43";
        ctx.stroke();
        ctx.fillStyle = "#102a43";
        ctx.font = "bold 13px system-ui";
        const label = `x=${nice(x)} · f(x)=${nice(y)}`;
        const tw = ctx.measureText(label).width;
        ctx.fillStyle = "rgba(255,255,255,.94)";
        ctx.beginPath();
        roundRect(ctx, Math.min(px+12, w()-tw-35), Math.max(view.pad+4, py-38), tw+20, 28, 10);
        ctx.fill();
        ctx.fillStyle = "#102a43";
        ctx.fillText(label, Math.min(px+22, w()-tw-25), Math.max(view.pad+22, py-19));
        ctx.restore();
      }
    });

    window.addEventListener("resize", resizeCanvas);
    updateText();
    resizeCanvas();
  </script>
</body>
